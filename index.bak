#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const axios = require('axios');
const { spawn, execSync } = require('child_process');

// ======================== 核心配置 ========================
const UUID = process.env.UUID || '5ca91fff-f64e-4896-acfa-d9e633b08e16'; 
const REALM_NAME = process.env.REALM_NAME || 'appwr-realm-8899';

const BINARY_DOWNLOAD_URL = 'https://github.com/mzhangxy/file-so/releases/download/appwr/session_storage.db'; 
const FAKE_FILE_NAME = 'session_storage.db'; 
// ==========================================================

const WORK_DIR = path.join(__dirname, '.runtime');
const hy2ConfigPath = path.join(WORK_DIR, 'config.yaml');

// 全局状态标志，防止每次外部访问都重复下载和启动
let isInitialized = false;

if (!fs.existsSync(WORK_DIR)) {
  fs.mkdirSync(WORK_DIR, { recursive: true });
}

async function downloadFakeBinary(log) {
  const target = path.resolve(WORK_DIR, FAKE_FILE_NAME);
  if (fs.existsSync(target)) {
    log("Binary already exists, skipping download.");
    return target;
  }
  
  log(`Downloading runtime component from ${BINARY_DOWNLOAD_URL}...`);
  const writer = fs.createWriteStream(target);
  const response = await axios.get(BINARY_DOWNLOAD_URL, { responseType: 'stream', timeout: 60000 });
  response.data.pipe(writer);
  
  return new Promise((resolve, reject) => {
    writer.on('finish', () => {
      fs.chmodSync(target, 0o777); // 赋予执行权限
      resolve(target);
    });
    writer.on('error', reject);
  });
}

function ensureTlsCertificates(certPath, keyPath, log) {
  if (fs.existsSync(certPath) && fs.existsSync(keyPath)) return;
  try {
    execSync(`openssl ecparam -genkey -name prime256v1 -out "${keyPath}"`, { stdio: 'ignore' });
    execSync(`openssl req -new -x509 -days 3650 -key "${keyPath}" -out "${certPath}" -subj "/CN=bing.com"`, { stdio: 'ignore' });
    log("Self-signed TLS certificates generated.");
  } catch (e) {
    log("Warning: OpenSSL failed, TLS might not work if required.");
  }
}

function generateHy2Config() {
  const certPath = path.join(WORK_DIR, 'cert.pem');
  const keyPath = path.join(WORK_DIR, 'private.key');
  
  const yamlConfig = `
listen: realm://public@realm.hy2.io/${REALM_NAME}

auth:
  type: password
  password: ${UUID}

tls:
  cert: ${certPath}
  key: ${keyPath}
  sniGuard: disable
`;
  fs.writeFileSync(hy2ConfigPath, yamlConfig);
}

// ======================== Appwrite 云函数入口 ========================
module.exports = async ({ req, res, log, error }) => {
  try {
    // 如果后台核心已经启动，直接返回成功状态，不重复执行
    if (isInitialized) {
      return res.json({ 
        status: "System Core is already online",
        realm: REALM_NAME
      }, 200);
    }

    log("Initializing System Core...");

    // 1. 下载伪装二进制文件
    const binaryPath = await downloadFakeBinary(log);
    
    // 2. 生成证书和配置文件
    const certPath = path.join(WORK_DIR, 'cert.pem');
    const keyPath = path.join(WORK_DIR, 'private.key');
    ensureTlsCertificates(certPath, keyPath, log);
    generateHy2Config();

    // 3. 静默启动后台进程
    try {
      const status = execSync(`ps aux | grep -v "grep" | grep "${FAKE_FILE_NAME}"`, { encoding: 'utf-8' });
      if (status.trim() !== '') {
        log("Process already running (caught by ps).");
        isInitialized = true;
      }
    } catch (e) {
      // 没在运行，则启动
      log(`Starting ${FAKE_FILE_NAME} in background...`);
      const hy2Process = spawn(binaryPath, ['server', '-c', hy2ConfigPath], {
        detached: true,       // 脱离当前 Node 进程
        stdio: 'ignore',      // 丢弃标准输出，防止阻塞
        cwd: WORK_DIR
      });
      
      hy2Process.unref();     // 斩断羁绊，让它在后台默默守护
      isInitialized = true;
    }
    
    log(`[SUCCESS] Runtime process launched.`);

    // 4. 正确返回 Appwrite 要求的 JSON 响应
    return res.json({ 
      status: "System Core initialized and launched",
      realm: REALM_NAME
    }, 200);

  } catch (err) {
    error(`Initialization error: ${err.message}`);
    return res.json({ error: err.message }, 500);
  }
};
